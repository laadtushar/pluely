# ─── AI Provider Config ───────────────────────────────────────────────────────
AI_PROVIDER=ollama

# Default model (shown first, used when no model selected in app)
AI_MODEL=qwen2.5-coder:14b

# ─── Ollama endpoint (default) ────────────────────────────────────────────────
# CUSTOM_CHAT_URL=http://localhost:11434/v1/chat/completions

# ─── Jan.ai / LM Studio on port 1337 ─────────────────────────────────────────
# To use Jan.ai or LM Studio instead, uncomment these two lines:
# CUSTOM_CHAT_URL=http://127.0.0.1:1337/v1/chat/completions
# AI_MODEL=your-model-name-from-jan

# Ollama doesn't need an API key — leave blank
AI_API_KEY=ollama

# ─── STT (Whisper) ────────────────────────────────────────────────────────────
CUSTOM_AUDIO_URL=http://localhost:8000/v1/audio/transcriptions
AUDIO_MODEL=Systran/faster-whisper-base

# ─── Server Config ────────────────────────────────────────────────────────────
PORT=3001
