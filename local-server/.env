# ─── AI Provider Config ───────────────────────────────────────────────────────
AI_PROVIDER=ollama

# Default model (shown first, used when no model selected in app)
AI_MODEL=phi4-reasoning:14b

# Fallback fast model
FALLBACK_MODEL=qwen2.5-coder:1.5b

# ─── Ollama endpoint ──────────────────────────────────────────────────────────
CUSTOM_CHAT_URL=http://localhost:11434/v1/chat/completions
CUSTOM_AUDIO_URL=

# Ollama doesn't need an API key — leave blank
AI_API_KEY=ollama

# ─── Server Config ────────────────────────────────────────────────────────────
PORT=3001
